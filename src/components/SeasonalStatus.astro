---
type SeasonItem = {
  title: string;
  months: string;
  status: "green" | "yellow" | "red";
  summary: string;
  highlights: string[];
};

type Props = {
  items: SeasonItem[];
};

const { items } = Astro.props;

const statusClasses = {
  green: "bg-safe/14 text-forest border-safe/18",
  yellow: "bg-warning/14 text-charcoal border-warning/18",
  red: "bg-danger/14 text-charcoal border-danger/18"
};

const dotClasses = {
  green: "bg-safe",
  yellow: "bg-warning",
  red: "bg-danger"
};
---

<div class="grid gap-5 lg:grid-cols-2">
  {
    items.map((item, index) => (
      <article class="panel p-6" data-reveal style={`animation-delay:${index * 90}ms`}>
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-charcoal/45">{item.months}</p>
            <h3 class="mt-3 text-2xl font-semibold tracking-[-0.03em] text-charcoal">{item.title}</h3>
          </div>
          <div class:list={["inline-flex items-center border px-3 py-3", statusClasses[item.status]]} aria-label={item.status}>
            <span class:list={["status-dot h-2.5 w-2.5", dotClasses[item.status]]}></span>
          </div>
        </div>
        <p class="mt-4 text-sm leading-7 text-charcoal/72">{item.summary}</p>
        <ul class="mt-5 grid gap-3 text-sm leading-6 text-charcoal/68">
          {item.highlights.map((highlight) => <li class="border border-charcoal/8 bg-fog/70 px-4 py-3">{highlight}</li>)}
        </ul>
      </article>
    ))
  }
</div>
