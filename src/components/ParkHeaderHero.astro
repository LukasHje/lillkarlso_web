---
import { getLocaleUrl } from "@/lib/site";
import type { Locale } from "@/lib/i18n";

type Props = {
  locale: Locale;
  title: string;
  designation: string;
  location: string;
  image: string;
  compact?: boolean;
};

const { locale, title, designation, location, image, compact = false } = Astro.props;
---

<section class:list={["relative overflow-hidden bg-night", compact ? "min-h-[15.5rem] sm:min-h-[16.5rem]" : "min-h-[21rem] sm:min-h-[27rem]"]}>
  <img src={image} alt="" class="absolute inset-0 h-full w-full object-cover" loading="eager" />
  <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(10,10,10,0.12),rgba(10,10,10,0.18)_34%,rgba(10,10,10,0.5)_68%,rgba(10,10,10,0.72)_100%)]"></div>

  <div class="container-shell absolute inset-x-0 bottom-0 z-10">
    <div class="flex items-end pb-7 pt-16 sm:pb-8">
      <div class="flex flex-col gap-2 text-white sm:flex-row sm:items-end sm:gap-6">
        <h1 class="text-4xl font-semibold leading-none tracking-[-0.04em] sm:text-[3.55rem]">
          <a href={getLocaleUrl(locale, "home")} class="hover:underline">{title}</a>
        </h1>
        <div class="pb-1">
          <p class="text-[1.05rem] font-semibold leading-5">{designation}</p>
          <p class="text-[1.05rem] font-semibold leading-5">{location}</p>
        </div>
      </div>
    </div>
  </div>
</section>
