---
type Tour = {
  title: string;
  duration: string;
  season: string;
  difficulty: string;
  summary: string;
  highlights: string[];
};

type Props = {
  tour: Tour;
};

const { tour } = Astro.props;
---

<article class="panel overflow-hidden p-6">
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-moss">{tour.season}</p>
      <h3 class="mt-3 font-serif text-3xl text-charcoal">{tour.title}</h3>
    </div>
    <div class="rounded-[1.5rem] bg-fog/70 px-4 py-3 text-right">
      <p class="text-xs uppercase tracking-[0.22em] text-charcoal/42">{tour.duration}</p>
      <p class="mt-2 text-sm font-semibold text-charcoal">{tour.difficulty}</p>
    </div>
  </div>
  <p class="mt-5 text-sm leading-7 text-charcoal/72">{tour.summary}</p>
  <ul class="mt-5 grid gap-3 text-sm leading-6 text-charcoal/70">
    {tour.highlights.map((highlight) => <li class="rounded-2xl border border-charcoal/8 bg-white/60 px-4 py-3">{highlight}</li>)}
  </ul>
</article>
