---
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import type { Locale } from "@/lib/i18n";
import type { PageKey } from "@/lib/site";
import { getLocaleUrl } from "@/lib/site";
import { t } from "@/lib/i18n";

type Props = {
  locale: Locale;
  routeKey: PageKey;
};

const { locale, routeKey } = Astro.props;
const messages = t(locale);
---

<header class="relative z-40 bg-black text-white">
  <div class="container-shell flex items-center justify-between gap-4 py-3">
    <div class="flex items-center gap-4">
      <a href={getLocaleUrl(locale, "home")} class="shrink-0">
        <p class="text-[1.05rem] font-semibold text-white sm:text-[1.1rem]">Naturskyddsföreningen</p>
      </a>
      <p class="hidden text-sm text-white/72 lg:block">{messages.site.brand}</p>
    </div>

    <div class="flex items-center gap-4">
      <LanguageSwitcher locale={locale} routeKey={routeKey} />
    </div>
  </div>
</header>
