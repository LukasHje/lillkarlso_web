---
import type { SiteAlert } from "@/lib/alerts";
import {
  formatAlertDate,
  getAlertLevelMeta,
  getAlertSummary,
  remainingAlertsAreLowerSeverity
} from "@/lib/alerts";
import type { Locale } from "@/lib/i18n";
import { t } from "@/lib/i18n";

type Props = {
  locale: Locale;
  alerts: SiteAlert[];
  href: string;
};

const { locale, alerts, href } = Astro.props;
const messages = t(locale);
const summary = getAlertSummary(alerts);
const primary = summary.primary;
const showLowerSeverityCopy = remainingAlertsAreLowerSeverity(primary, summary.remaining);
const remainingLabel =
  summary.remaining.length > 0
    ? (showLowerSeverityCopy ? messages.alerts.moreNonEmergency : messages.alerts.moreAlerts).replace(
        "{count}",
        String(summary.remaining.length)
      )
    : "";

const statusStyles = {
  red: "text-[#d52a2a]",
  yellow: "text-[#e67e22]",
  green: "text-[#2b62b7]"
};
---

<section class="rounded-[0.5rem] border border-charcoal/14 bg-white">
  <div class="flex flex-wrap items-start justify-between gap-4 px-5 pb-0 pt-5 sm:px-6 sm:pt-6">
    <div class="flex items-center gap-3">
      <span class="inline-flex bg-[#7b210f] px-3 py-2 text-xs font-semibold uppercase tracking-[0.08em] text-white">
        {messages.alerts.inEffect}
      </span>
    </div>
    <button data-alert-dismiss class="text-sm font-semibold text-forest">{locale === "sv" ? "AVVISA ×" : "DISMISS ×"}</button>
  </div>

  {
    primary ? (
      <div class="px-5 pt-8 sm:px-6">
        <div class="grid gap-5 sm:grid-cols-[3rem_1fr]">
          <div class:list={["flex items-start justify-center", statusStyles[getAlertLevelMeta(primary.level, locale).status]]}>
          {
            primary.level === "closure" ? (
              <svg viewBox="0 0 20 20" class="mt-1 h-8 w-8" aria-hidden="true">
                <path d="M6 10h8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
                <circle cx="10" cy="10" r="7.2" fill="none" stroke="currentColor" stroke-width="1.6"></circle>
              </svg>
            ) : primary.level === "caution" ? (
              <svg viewBox="0 0 20 20" class="mt-1 h-8 w-8" aria-hidden="true">
                <path d="M10 4.1 16.2 15H3.8L10 4.1Zm0 3.4v3.8m0 2.1h.01" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            ) : (
              <svg viewBox="0 0 20 20" class="mt-1 h-8 w-8" aria-hidden="true">
                <path d="M10 8.3v4.7M10 5.3h.01M17 10a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            )
          }
        </div>

          <div class="pb-0">
            <p class="text-[0.72rem] font-semibold uppercase tracking-[0.02em] text-charcoal/62">{getAlertLevelMeta(primary.level, locale).label}</p>
            <h2 class="mt-2 max-w-6xl text-[2.15rem] font-medium leading-tight tracking-[-0.03em] text-charcoal sm:text-[2.2rem]">{primary.title}</h2>
            <p class="mt-1 text-[1rem] text-charcoal">
              {messages.alerts.datePosted}: {formatAlertDate(primary.posted, locale)}
            </p>
            <p class="mt-2 max-w-6xl text-[1rem] leading-8 text-charcoal">{primary.body}</p>
            <div class="mt-6 flex flex-wrap gap-3">
              {primary.locations.map((location) => <span class="border border-charcoal/12 bg-[#efebe2] px-4 py-2 text-[0.95rem] text-charcoal/72">{location}</span>)}
            </div>
          </div>
        </div>
      </div>
    ) : (
      <div class="px-5 py-5 text-base leading-7 text-charcoal/70">
        {messages.alerts.noneActive}
      </div>
    )
  }

  {
    remainingLabel && (
      <div class="px-5 pt-8 sm:px-6">
        <a href={href} class="text-[1rem] text-[#4e2a97] underline underline-offset-2">+ {remainingLabel}...</a>
      </div>
    )
  }

  <div class="flex flex-wrap gap-3 px-5 pb-6 pt-8 sm:px-6 sm:pb-7">
    <button data-alert-dismiss class="min-h-12 border-2 border-forest px-6 text-[1rem] font-semibold text-forest">{locale === "sv" ? "Avvisa" : "Dismiss"}</button>
    <a href={href} class="inline-flex min-h-12 items-center border-2 border-forest px-6 text-[1rem] font-semibold text-forest">
      {messages.alerts.viewAll}
    </a>
  </div>
</section>

<script>
  document.querySelectorAll("[data-alert-dismiss]").forEach((button) => {
    button.addEventListener("click", () => {
      const root = button.closest("section");
      if (root instanceof HTMLElement) {
        if (root.dataset.alertClosing === "true") {
          return;
        }

        root.dataset.alertClosing = "true";
        root.addEventListener(
          "animationend",
          () => {
            root.style.display = "none";
          },
          { once: true }
        );
      }
    });
  });
</script>
