---
import type { Locale } from "@/lib/i18n";
import type { PageKey, QuickAction } from "@/lib/site";
import { getNavigationGroups, getQuickActionLinks } from "@/lib/site";

type Props = {
  locale: Locale;
  routeKey: PageKey;
  alertCount?: number;
};

const { locale, routeKey, alertCount = 0 } = Astro.props;
const groups = getNavigationGroups(locale);
const actions: QuickAction[] = getQuickActionLinks(locale).map((action) =>
  action.icon === "alerts"
    ? {
        ...action,
        badgeCount: alertCount
      }
    : action
);
const quickActionGridClass =
  actions.length === 4 ? "grid-cols-4" : actions.length === 5 ? "grid-cols-5" : "grid-cols-6";

function iconMarkup(icon: "info" | "alerts" | "weather" | "boat" | "map" | "tours") {
  if (icon === "info") {
    return '<path d="M10 8.5v5M10 5.25h.01M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>';
  }

  if (icon === "alerts") {
    return '<path d="M10 3.2 17 16.8H3L10 3.2Zm0 4.2v4.2m0 2.2h.01" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>';
  }

  if (icon === "weather") {
    return '<path d="M6.2 14.7h7.4a3.1 3.1 0 0 0 .5-6.2 4.5 4.5 0 0 0-8.6 1.4A2.5 2.5 0 0 0 6.2 14.7Zm.8 2.1 1.1 1.7m2.2-1.7 1.1 1.7m2.2-1.7 1.1 1.7" fill="none" stroke="currentColor" stroke-width="1.55" stroke-linecap="round" stroke-linejoin="round"></path>';
  }

  if (icon === "boat") {
    return '<path d="M3.5 11.8h13l-1.7 3.2H5.2l-1.7-3.2Zm2.7-2.6h7.6l-1-2.3H7.2l-1 2.3Zm-1.4 6.4c1 .9 2 .9 3 0 .9.9 1.9.9 2.8 0 .9.9 1.9.9 2.8 0 .9.9 2 .9 3 0" fill="none" stroke="currentColor" stroke-width="1.55" stroke-linecap="round" stroke-linejoin="round"></path>';
  }

  if (icon === "map") {
    return '<path d="M10 17s4.5-4.6 4.5-8.1A4.5 4.5 0 1 0 5.5 8.9C5.5 12.4 10 17 10 17Zm0-6.3a1.8 1.8 0 1 0 0-3.6 1.8 1.8 0 0 0 0 3.6Z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>';
  }

  return '<path d="M4 5.5h12v10H4zM7 3.5v4M13 3.5v4M6.5 10h3M10.5 10h3M6.5 13h3" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>';
}

function navAdornment(group: (typeof groups)[number]) {
  return group.external ? "external" : "none";
}
---

<section class="bg-black text-white">
  <div class="container-shell hidden items-stretch justify-between lg:flex">
    <nav class="flex items-stretch" aria-label="Park sections">
      {
        groups.map((group) => (
          <a href={group.href} target={group.external ? "_blank" : undefined} rel={group.external ? "noreferrer" : undefined} class="inline-flex min-h-[4.4rem] items-center gap-2 px-5 text-[0.92rem] font-semibold text-white">
            {group.title}
            {
              navAdornment(group) === "external" ? (
                <svg viewBox="0 0 20 20" class="h-3.5 w-3.5" aria-hidden="true">
                  <path d="M8 4.5H4.5v11H15.5V12M10 10 15.5 4.5M11 4.5h4.5V9" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              ) : null
            }
          </a>
        ))
      }
    </nav>

    <div class:list={["grid border-l border-white/12", quickActionGridClass]}>
      {
        actions.map((action) => (
          <a
            href={action.href}
            target={action.external ? "_blank" : undefined}
            rel={action.external ? "noreferrer" : undefined}
            class:list={[
              "relative flex min-w-[6rem] flex-col items-center justify-center gap-2 border-r border-white/12 px-3 py-3 text-center",
              action.activeKeys.includes(routeKey) ? "bg-[#404040]" : "bg-black"
            ]}
          >
            {
              action.badgeCount ? (
                <span class="absolute left-[calc(50%+0.8rem)] top-[2.2rem] inline-flex min-w-4 items-center justify-center bg-[#d55f23] px-1.5 py-0.5 text-[0.72rem] font-semibold leading-none text-white">
                  {action.badgeCount}
                </span>
              ) : null
            }
            <span class="text-[0.68rem] font-semibold uppercase tracking-[0.08em]">{action.label}</span>
            <svg viewBox="0 0 20 20" class="h-7 w-7" aria-hidden="true" set:html={iconMarkup(action.icon)} />
          </a>
        ))
      }
    </div>
  </div>

  <div class="container-shell py-3 lg:hidden">
    <div class="grid grid-cols-2 gap-2">
      {
        actions.map((action) => (
          <a href={action.href} target={action.external ? "_blank" : undefined} rel={action.external ? "noreferrer" : undefined} class="border border-white/12 px-3 py-3 text-center text-xs font-semibold uppercase tracking-[0.08em] text-white">
            {action.label}
          </a>
        ))
      }
    </div>
    <div class="mt-3 flex flex-wrap gap-3 text-sm">
      {groups.map((group) => <a href={group.href} class="text-white underline underline-offset-4">{group.title}</a>)}
    </div>
  </div>
</section>
