---
type Item = {
  label: string;
  href: string;
  description: string;
  external?: boolean;
};

type Props = {
  title: string;
  href: string;
  items: Item[];
  active?: boolean;
  external?: boolean;
};

const { title, href, items, active = false, external = false } = Astro.props;
---

<div class="group relative">
  <a
    href={href}
    target={external ? "_blank" : undefined}
    rel={external ? "noreferrer" : undefined}
    class:list={[
      "inline-flex min-h-[4.5rem] items-center gap-2 border-r border-white/10 px-5 py-4 text-sm font-semibold tracking-[0.16em] uppercase transition",
      active ? "bg-white/8 text-white" : "text-fog/80 hover:bg-white/6 hover:text-white"
    ]}
  >
    {title}
    <svg viewBox="0 0 20 20" class="h-3.5 w-3.5 opacity-70" aria-hidden="true">
      <path d="M5 7.5 10 12.5 15 7.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </a>

  <div class="pointer-events-none invisible absolute left-0 top-full z-30 w-[25rem] opacity-0 transition duration-300 ease-[var(--ease-quiet)] group-hover:pointer-events-auto group-hover:visible group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:visible group-focus-within:opacity-100">
    <div class="panel-dark p-5">
      <div class="mb-4 border-b border-white/10 pb-4">
        <p class="section-kicker text-limestone/70">Explore</p>
        <p class="mt-2 text-2xl font-semibold text-white">{title}</p>
      </div>
      <div class="grid gap-3">
        {
          items.map((item) => (
            <a href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noreferrer" : undefined} class="border border-white/0 px-4 py-3 transition hover:border-white/10 hover:bg-white/6 focus-visible:border-limestone/70 focus-visible:bg-white/6">
              <p class="text-base font-semibold uppercase tracking-[0.06em] text-white">{item.label}</p>
              <p class="mt-2 text-sm leading-6 text-fog/72">{item.description}</p>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</div>
