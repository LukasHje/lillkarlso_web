---
import type { SiteAlert } from "@/lib/alerts";
import {
  formatAlertDate,
  getAlertLevelMeta,
  getUniqueAlertLocations,
  groupAlertsByLevel
} from "@/lib/alerts";
import SectionBreadcrumbs from "@/components/SectionBreadcrumbs.astro";
import type { Locale } from "@/lib/i18n";
import { t } from "@/lib/i18n";

type Props = {
  locale: Locale;
  alerts: SiteAlert[];
};

const { locale, alerts } = Astro.props;
const messages = t(locale);
const grouped = groupAlertsByLevel(alerts);
const locations = getUniqueAlertLocations(alerts);

const iconStyles = {
  red: "text-[#d52a2a]",
  yellow: "text-[#e67e22]",
  green: "text-[#2b62b7]"
};

const titleStyles = {
  red: "text-[#d52a2a]",
  yellow: "text-[#e67e22]",
  green: "text-[#2b62b7]"
};

const groups = [
  ["closure", grouped.closure],
  ["caution", grouped.caution],
  ["information", grouped.information]
] as const;
---

<section class="container-shell py-8 sm:py-10">
  <div class="max-w-6xl">
    <SectionBreadcrumbs locale={locale} currentLabel={messages.alerts.pageTitle} />

    <h1 class="mt-8 text-balance font-sans text-[4rem] font-semibold tracking-[-0.05em] text-charcoal sm:text-[4.2rem]">
      {messages.alerts.pageTitle}
    </h1>
    <div class="mt-8 border-b border-charcoal/10"></div>
    <span class="mt-6 inline-flex bg-black px-3 py-2 text-xs font-semibold uppercase tracking-[0.22em] text-white">
      {messages.navigation.alerts}
    </span>
  </div>

  <div class="mt-14 grid gap-10 xl:grid-cols-[0.96fr_0.74fr] xl:items-start">
    <div class="space-y-12">
      {
        groups.map(([level, items]) => {
          if (items.length === 0) return null;

          const meta = getAlertLevelMeta(level, locale);

          return (
            <section class="space-y-5">
              <h2 class="text-[3rem] font-semibold tracking-[-0.04em] text-charcoal">{meta.label}</h2>
              <div class="divide-y divide-charcoal/10 border-b border-charcoal/10">
                {items.map((alert) => {
                  const itemMeta = getAlertLevelMeta(alert.level, locale);

                  return (
                    <article class="grid gap-5 py-7 sm:grid-cols-[5rem_1fr]">
                      <div class:list={["mt-2 flex h-8 w-8 items-center justify-center", iconStyles[itemMeta.status]]}>
                        {
                          alert.level === "closure" ? (
                            <svg viewBox="0 0 20 20" class="h-5 w-5" aria-hidden="true">
                              <path d="M6 10h8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
                              <circle cx="10" cy="10" r="7.2" fill="none" stroke="currentColor" stroke-width="1.6"></circle>
                            </svg>
                          ) : alert.level === "caution" ? (
                            <svg viewBox="0 0 20 20" class="h-5 w-5" aria-hidden="true">
                              <path d="M10 4.1 16.2 15H3.8L10 4.1Zm0 3.4v3.8m0 2.1h.01" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                          ) : (
                            <svg viewBox="0 0 20 20" class="h-5 w-5" aria-hidden="true">
                              <path d="M10 8.3v4.7M10 5.3h.01M17 10a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                          )
                        }
                      </div>

                      <div>
                        <h3 class:list={["max-w-3xl text-balance text-[1.65rem] leading-tight font-semibold tracking-[-0.03em]", titleStyles[itemMeta.status]]}>
                          {alert.title}
                        </h3>
                        <p class="mt-2 text-[1.05rem] text-charcoal">
                          {messages.alerts.datePosted}: {formatAlertDate(alert.posted, locale)}
                        </p>
                        <p class="mt-3 max-w-3xl text-[1rem] leading-9 text-charcoal">{alert.body}</p>
                        <a href="#" class="mt-3 inline-flex text-[1.05rem] font-semibold text-[#005ea2]">{locale === "sv" ? "mer ›" : "more ›"}</a>
                      </div>
                    </article>
                  );
                })}
              </div>
            </section>
          );
        })
      }
    </div>

    <aside class="space-y-8 xl:sticky xl:top-8">
      <section>
        <h2 class="text-[2.25rem] font-semibold tracking-[-0.04em] text-charcoal">{messages.alerts.locationsTitle}</h2>
        <div class="mt-6 border border-charcoal/12 bg-white p-4">
          <div class="aspect-[1.15/1] border border-charcoal/10 bg-[#f5f1e9] p-6">
            <svg viewBox="0 0 860 540" class="h-full w-full" role="img" aria-label={messages.alerts.locationsTitle}>
              <defs>
                <linearGradient id="sea-conditions" x1="0" x2="1">
                  <stop offset="0%" stop-color="#f1ece4"></stop>
                  <stop offset="100%" stop-color="#efe8dc"></stop>
                </linearGradient>
                <linearGradient id="land-conditions" x1="0" x2="1">
                  <stop offset="0%" stop-color="#e0dcc8"></stop>
                  <stop offset="100%" stop-color="#d7d2bd"></stop>
                </linearGradient>
              </defs>
              <rect width="860" height="540" fill="url(#sea-conditions)"></rect>
              <path d="M266 130c66-42 154-48 223-3 56 37 86 116 60 183-21 56-78 104-140 117-72 16-157 2-210-52-55-57-62-145-29-206 17-30 51-59 96-39Z" fill="url(#land-conditions)" stroke="#a9b282" stroke-width="6"></path>
              <path d="M265 130c44 24 63 68 86 104 18 28 43 53 89 71 35 13 71 17 109 14" fill="none" stroke="#9eb26d" stroke-width="5"></path>
              <path d="M180 90v60M180 90h30M180 150h30" stroke="#333" stroke-width="5"></path>
              <path d="M190 190h20" stroke="#333" stroke-width="5"></path>
              <circle cx="165" cy="360" r="7" fill="#111"></circle>
              <circle cx="410" cy="292" r="7" fill="#111"></circle>
              <circle cx="515" cy="198" r="7" fill="#111"></circle>
              <circle cx="585" cy="340" r="7" fill="#111"></circle>
            </svg>
          </div>
        </div>
      </section>

      <section class="border border-charcoal/12 bg-white p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-charcoal/58">{messages.alerts.locationSummary}</p>
        <p class="mt-3 text-base leading-8 text-charcoal">{messages.alerts.locationSummaryText}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {locations.map((location) => <span class="border border-charcoal/10 bg-white px-3 py-1 text-sm text-charcoal/78">{location}</span>)}
        </div>
      </section>

      <section class="border-t border-charcoal/10 pt-8">
        <h2 class="text-[2.1rem] font-semibold tracking-[-0.04em] text-charcoal">{locale === "sv" ? "Väder" : "Weather"}</h2>
        <div class="mt-5 space-y-4 text-[1rem] leading-8 text-charcoal">
          <p>{locale === "sv" ? "Förhållandena kan ändras snabbt beroende på vind, sjö och säsong. Kontrollera dagsaktuella prognoser och båttrafik innan avresa." : "Conditions can change quickly depending on wind, sea state, and season. Check current forecasts and boat access before travel."}</p>
          <p>{locale === "sv" ? "Aktuella vindförhållanden och översikt finns längre ned på sidan." : "Current wind conditions and a weather overview appear further down this page."}</p>
        </div>
      </section>
    </aside>
  </div>

  <section id="live-conditions" class="mt-16 border-t border-charcoal/10 pt-10">
    <div class="max-w-5xl">
      <h2 class="text-[2.25rem] font-semibold tracking-[-0.04em] text-charcoal">{locale === "sv" ? "Weather" : "Weather"}</h2>
      <p class="mt-4 text-[1rem] leading-8 text-charcoal">
        {locale === "sv"
          ? "Vind, riktning och temperatur påverkar dagens praktiska angöring. Se aktuell lägesbild nedan."
          : "Wind, direction, and temperature affect the practical landing conditions for the day. See the current status below."}
      </p>
    </div>
  </section>
</section>
