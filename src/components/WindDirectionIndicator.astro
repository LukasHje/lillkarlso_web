---
type Props = {
  degrees: number;
  label: string;
  title?: string;
};

const { degrees, label, title = "Wind direction" } = Astro.props;
const rotation = `transform: translateX(-50%) translateY(-86%) rotate(${degrees}deg);`;
---

<div class="flex items-center gap-4 rounded-[1.5rem] border border-charcoal/8 bg-white/55 px-4 py-4">
  <div class="relative h-16 w-16 rounded-full border border-charcoal/10 bg-fog/80">
    <div class="absolute inset-2 rounded-full border border-charcoal/10"></div>
    <span class="absolute left-1/2 top-1.5 -translate-x-1/2 text-[0.62rem] font-semibold uppercase tracking-[0.2em] text-charcoal/45">N</span>
    <div class="absolute left-1/2 top-1/2 h-6 w-0.5 rounded-full bg-forest origin-bottom" style={rotation} data-wind-arrow></div>
    <div class="absolute left-1/2 top-1/2 h-3 w-3 -translate-x-1/2 -translate-y-1/2 rounded-full bg-night"></div>
  </div>
  <div>
    <p class="text-xs uppercase tracking-[0.22em] text-charcoal/45">{title}</p>
    <p class="mt-1 text-base font-semibold text-charcoal" data-wind-label>{label}</p>
  </div>
</div>
