---
type Fact = {
  label: string;
  value: string;
};

type Props = {
  facts: Fact[];
};

const { facts } = Astro.props;
---

<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
  {
    facts.map((fact) => (
      <article class="panel bg-grain p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-charcoal/45">{fact.label}</p>
        <p class="mt-4 font-serif text-3xl leading-tight text-charcoal">{fact.value}</p>
      </article>
    ))
  }
</div>
