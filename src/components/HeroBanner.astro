---
type Link = {
  label: string;
  href: string;
  badgeCount?: number;
};

type MetaItem = {
  label: string;
  value: string;
  tone?: "neutral" | "alert" | "caution" | "safe";
};

type Props = {
  kicker: string;
  title: string;
  intro: string;
  image: string;
  location?: string;
  metaItems?: MetaItem[];
  cta?: Link;
  secondaryCta?: Link;
  alertCta?: Link;
  compact?: boolean;
  variant?: "default" | "home";
};

const { kicker, title, intro, image, location, metaItems = [], cta, secondaryCta, compact = false, variant = "default" } = Astro.props;

const metaToneClasses = {
  neutral: "text-white",
  alert: "text-[#efb294]",
  caution: "text-[#f0c276]",
  safe: "text-[#bfd4b8]"
};
---

<section class:list={["relative overflow-hidden", compact ? "min-h-[38rem]" : "min-h-[72svh]"]}>
  <div class="absolute inset-0 overflow-hidden bg-night">
    <img src={image} alt="" class="h-full w-full object-cover opacity-90" loading="eager" />
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(12,14,12,0.12),rgba(12,14,12,0.2)_34%,rgba(12,14,12,0.42)_62%,rgba(12,14,12,0.74)_100%)]"></div>
  </div>

  {
    variant === "home" ? (
      <div class="relative z-10 flex min-h-[28rem] items-end sm:min-h-[31rem]">
        <div class="w-full border-t border-white/10 bg-[#171916]/90 text-fog">
          <div class="container-shell grid lg:grid-cols-[1.05fr_0.95fr]">
            <div class="py-6 sm:py-7">
              <p class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-limestone/84">{kicker}</p>
              <h1 class="mt-3 text-4xl font-semibold tracking-[-0.05em] text-white sm:text-[3.8rem] lg:text-[4.15rem]">
                {title}
              </h1>
              {location && <p class="mt-2 text-sm font-semibold uppercase tracking-[0.18em] text-fog/72">{location}</p>}
              <p class="mt-4 max-w-2xl text-sm leading-6 text-fog/78 sm:text-base">{intro}</p>
            </div>

            <div class="grid border-t border-white/10 sm:grid-cols-2 lg:border-l lg:border-t-0">
              {
                metaItems.map((item, index) => (
                  <div class:list={["border-white/10 px-5 py-5", index % 2 === 0 ? "sm:border-r" : "", index < metaItems.length - 2 ? "border-b" : "border-b sm:border-b-0 lg:border-b" ]}>
                    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-fog/54">{item.label}</p>
                    <p class:list={["mt-3 text-xl font-semibold leading-tight tracking-[-0.03em]", metaToneClasses[item.tone ?? "neutral"]]}>{item.value}</p>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    ) : (
      <div class="container-shell relative z-10">
        <div class:list={[compact ? "flex min-h-[34rem] items-end pb-12 sm:min-h-[36rem] sm:pb-14" : "flex min-h-[64svh] items-end pb-10 sm:pb-14"]}>
          <div class="max-w-4xl" data-reveal>
            <p class="section-kicker text-limestone">{kicker}</p>
            <h1 class:list={["mt-5 text-balance text-white drop-shadow-[0_8px_30px_rgba(0,0,0,0.26)]", compact ? "text-5xl font-semibold leading-[0.95] tracking-[-0.05em] sm:text-6xl lg:text-[4.8rem]" : "text-4xl font-semibold leading-[0.92] tracking-[-0.05em] sm:text-6xl lg:text-[5rem]"]}>
              {title}
            </h1>
            <p class="mt-6 max-w-2xl text-base leading-7 text-fog/82 sm:text-lg sm:leading-8">{intro}</p>

            {
              (cta || secondaryCta) && (
                <div class="mt-8 flex flex-wrap gap-3">
                  {cta && (
                    <a href={cta.href} class="inline-flex items-center bg-fog px-6 py-3 text-sm font-semibold uppercase tracking-[0.24em] text-night transition hover:bg-white">
                      {cta.label}
                    </a>
                  )}
                  {secondaryCta && (
                    <a href={secondaryCta.href} class="inline-flex items-center border border-white/18 bg-white/8 px-6 py-3 text-sm font-semibold uppercase tracking-[0.24em] text-white transition hover:bg-white/14">
                      {secondaryCta.label}
                    </a>
                  )}
                </div>
              )
            }
          </div>
        </div>
      </div>
    )
  }
</section>
