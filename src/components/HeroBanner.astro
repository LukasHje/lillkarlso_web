---
type Link = {
  label: string;
  href: string;
};

type Props = {
  kicker: string;
  title: string;
  intro: string;
  image: string;
  cta?: Link;
  secondaryCta?: Link;
  compact?: boolean;
};

const { kicker, title, intro, image, cta, secondaryCta, compact = false } = Astro.props;
---

<section class:list={["relative overflow-hidden pt-6", compact ? "min-h-[38rem]" : "min-h-[72svh]"]}>
  <div class="absolute inset-0 overflow-hidden rounded-[2rem] bg-night">
    <img src={image} alt="" class="h-full w-full object-cover opacity-90" loading="eager" />
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(10,12,11,0.42),rgba(10,12,11,0.56)_28%,rgba(10,12,11,0.72)_58%,rgba(10,12,11,0.9)_100%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_20%,rgba(255,255,255,0.12),transparent_18%),radial-gradient(circle_at_80%_10%,rgba(216,204,183,0.15),transparent_20%)]"></div>
  </div>

  <div class="container-shell relative z-10">
    <div class:list={[compact ? "flex min-h-[34rem] items-end pb-12 sm:min-h-[36rem] sm:pb-14" : "flex min-h-[64svh] items-end pb-10 sm:pb-14"]}>
      <div class="max-w-4xl" data-reveal>
        <p class="section-kicker text-limestone">{kicker}</p>
        <h1 class:list={["mt-5 font-serif text-white text-balance drop-shadow-[0_8px_30px_rgba(0,0,0,0.26)]", compact ? "text-5xl leading-[0.95] sm:text-6xl lg:text-7xl" : "text-4xl leading-[0.92] sm:text-6xl lg:text-[5rem]"]}>
          {title}
        </h1>
        <p class="mt-6 max-w-2xl text-base leading-7 text-fog/82 sm:text-lg sm:leading-8">{intro}</p>

        {
          (cta || secondaryCta) && (
            <div class="mt-8 flex flex-wrap gap-3">
              {cta && (
                <a href={cta.href} class="inline-flex items-center rounded-full bg-fog px-6 py-3 text-sm font-semibold uppercase tracking-[0.24em] text-night transition hover:bg-white">
                  {cta.label}
                </a>
              )}
              {secondaryCta && (
                <a href={secondaryCta.href} class="inline-flex items-center rounded-full border border-white/18 bg-white/8 px-6 py-3 text-sm font-semibold uppercase tracking-[0.24em] text-white transition hover:bg-white/14">
                  {secondaryCta.label}
                </a>
              )}
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
